{
  "name": "@decentralchain/signature-adapter",
  "version": "7.0.0",
  "description": "Multi-provider transaction signing adapter for DecentralChain blockchain",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-signature-adapter.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-signature-adapter#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-signature-adapter/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:publint": "publint",
    "check:exports": "attw --pack .",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "prepare": "lefthook install",
    "prepack": "npm run build",
    "postversion": "npm publish",
    "postpublish": "git push",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "150 kB"
    }
  ],
  "keywords": [
    "decentralchain",
    "dcc",
    "signature",
    "adapter",
    "ledger",
    "transaction",
    "blockchain",
    "signing",
    "wallet"
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "dependencies": {
    "@decentralchain/bignumber": "1.1.1",
    "@decentralchain/data-entities": "3.0.0",
    "@decentralchain/ledger": "5.0.0",
    "@decentralchain/money-like-to-node": "1.0.0",
    "@decentralchain/transactions": "5.0.0",
    "@decentralchain/ts-types": "2.0.0",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/ramda": "^0.31.1",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
